# Plantilla de variables de entorno — copiar a `.env` y rellenar valores reales.
# El archivo .env real está en .gitignore y nunca se commitea.

# === Resend (email transactional) ===
# Obtener en https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Spotify (Client Credentials flow) ===
# Crear app en https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_ARTIST_ID=23reXrP1oSrpgNVFHIEGk6

# === Admin / Sessions ===
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
ADMIN_EMAIL=

# === apps/web — Public API URL ===
# Variable expuesta al cliente (prefijo PUBLIC_). En dev apunta al wrangler local.
# En prod debe apuntar a la URL desplegada del worker (ej. https://api.noracx.com).
PUBLIC_API_URL=http://localhost:8787
