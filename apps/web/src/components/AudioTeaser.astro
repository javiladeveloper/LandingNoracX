---
import { type Lang } from '@/i18n';
interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8787';
---

<section id="teaser" class="border-blood/20 bg-coal relative border-y py-24 md:py-32">
  <div class="section flex w-full flex-col items-center justify-center" style="padding-top: 0; padding-bottom: 0;">
    <div class="w-full max-w-4xl">
      <div class="border-blood/40 bg-void relative w-full border-2 p-6 md:p-10 shadow-[0_0_30px_rgba(230,10,10,0.05)]">
      
      <!-- Cabecera del reproductor -->
      <div class="mb-8 flex items-center justify-between border-b border-blood/20 pb-4">
        <h2 class="text-blood-bright font-mono text-[11px] tracking-[0.3em] uppercase decrypt">
          {lang === 'es' ? 'Transmisión Segura' : 'Secure Feed'}
        </h2>
        <div class="flex items-center gap-2">
          <span class="bg-blood-bright h-2 w-2 animate-pulse rounded-full"></span>
          <span class="text-bone font-mono text-[10px] tracking-[0.2em] uppercase">Live</span>
        </div>
      </div>

      <!-- Estado -->
      <div class="mb-10 text-center">
        <h3 class="text-bone font-display text-2xl uppercase tracking-wider decrypt md:text-3xl" id="teaser-status">
          FRAGMENTO INTERCEPTADO
        </h3>
        <p class="text-ink-dim mt-2 font-mono text-[10px] tracking-[0.2em] uppercase">
          ID: NORACX_TSR_001 // ENCRIPTADO
        </p>
      </div>

      <!-- Player Raw -->
      <div class="flex flex-col md:flex-row gap-4">
        <!-- Play Button -->
        <button id="play-btn" data-api-url={apiUrl} class="bg-blood-bright text-bone hover:bg-bone hover:text-blood-bright flex h-14 w-full md:w-16 shrink-0 items-center justify-center transition-colors focus:outline-none">
          <svg class="h-6 w-6 translate-x-0.5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M8 5v14l11-7z" />
          </svg>
        </button>

        <!-- Progress Track -->
        <div class="bg-ash border-blood/20 relative flex h-14 flex-1 cursor-pointer items-center border" id="progress-container">
          <div id="progress-bar" class="bg-blood/30 absolute left-0 top-0 h-full w-0 transition-all duration-75 border-r border-blood-bright"></div>
          
          <!-- Tiempos superpuestos -->
          <div class="absolute inset-0 flex items-center justify-between px-4 pointer-events-none font-mono text-[11px] tracking-[0.2em]">
            <span id="time-current" class="text-bone">00:00</span>
            <span id="time-total" class="text-ink-dim">00:00</span>
          </div>

          <!-- Glitch lines inside progress -->
          <div class="absolute left-1/4 top-0 h-full w-px bg-white/5 pointer-events-none"></div>
          <div class="absolute left-1/2 top-0 h-full w-px bg-white/5 pointer-events-none"></div>
          <div class="absolute left-3/4 top-0 h-full w-px bg-white/5 pointer-events-none"></div>
        </div>
      </div>

    </div>
  </div>
</div>

  <audio id="teaser-audio" preload="metadata">
    <source src={`${apiUrl}/api/teaser`} />
  </audio>
</section>

<script>
  const playBtn = document.getElementById('play-btn');
  const audio = document.getElementById('teaser-audio') as HTMLAudioElement;
  const progressBar = document.getElementById('progress-bar');
  const progressContainer = document.getElementById('progress-container');
  const timeCurrent = document.getElementById('time-current');
  const timeTotal = document.getElementById('time-total');
  const teaserStatus = document.getElementById('teaser-status');

  let isPlaying = false;
  let hasTrackedPlay = false;

  if (playBtn && audio && progressBar && timeCurrent && progressContainer) {
    const apiUrl = playBtn.getAttribute('data-api-url') || '';

    // Cache buster dinámico: obligar al navegador a no usar la versión en caché del audio
    const sourceEl = audio.querySelector('source');
    if (sourceEl && !sourceEl.src.includes('?t=')) {
      sourceEl.src = sourceEl.src + '?t=' + Date.now();
      audio.load(); // Forzar recarga del source modificado
    }

    audio.addEventListener('loadedmetadata', () => {
      if (isFinite(audio.duration)) {
        const dMins = Math.floor(audio.duration / 60);
        const dSecs = Math.floor(audio.duration % 60);
        if (timeTotal) timeTotal.innerText = `${dMins.toString().padStart(2, '0')}:${dSecs.toString().padStart(2, '0')}`;
      }
    });

    playBtn.addEventListener('click', () => {
      if (isPlaying) {
        audio.pause();
        playBtn.innerHTML = '<svg class="w-6 h-6 translate-x-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>';
        if (teaserStatus) teaserStatus.innerText = 'FRAGMENTO INTERCEPTADO';
      } else {
        audio.play();
        playBtn.innerHTML = '<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>';
        if (teaserStatus) teaserStatus.innerText = 'REPRODUCIENDO...';
        
        if (!hasTrackedPlay && apiUrl) {
          hasTrackedPlay = true;
          fetch(`${apiUrl}/api/track/play`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: 'teaser' })
          }).catch(console.error);
        }
      }
      isPlaying = !isPlaying;
      
      // Glitch effect on button click
      playBtn.style.transform = 'translate(2px, 2px)';
      setTimeout(() => playBtn.style.transform = 'translate(0, 0)', 50);
    });

    audio.addEventListener('timeupdate', () => {
      const pct = (audio.currentTime / audio.duration) * 100;
      progressBar.style.width = `${pct}%`;
      
      const mins = Math.floor(audio.currentTime / 60);
      const secs = Math.floor(audio.currentTime % 60);
      timeCurrent.innerText = `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
    });

    progressContainer.addEventListener('click', (e) => {
      const rect = progressContainer.getBoundingClientRect();
      const pos = (e.clientX - rect.left) / rect.width;
      audio.currentTime = pos * audio.duration;
    });

    audio.addEventListener('ended', () => {
      isPlaying = false;
      playBtn.innerHTML = '<svg class="w-6 h-6 translate-x-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>';
      progressBar.style.width = '0%';
      timeCurrent.innerText = '00:00';
    });
  }
</script>
