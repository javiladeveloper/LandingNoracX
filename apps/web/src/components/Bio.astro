---
import { getDict, type Lang } from '@/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getDict(lang).bio;

// Imagen del artista: build-time fetch a /api/artist-image (que a su vez
// pulla en vivo de Spotify Web API). Así cuando el artista actualice su
// foto en Spotify for Artists, el siguiente rebuild la trae sola.
// Fallback hardcoded por si la API falla durante el build (la foto vieja
// es preferible a romper el render).
const FALLBACK_IMAGE = 'https://i.scdn.co/image/ab6761610000e5eb20ac7abb154d5ba3170c36e7';
const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8787';
let artistImage = FALLBACK_IMAGE;
try {
  const res = await fetch(`${apiUrl}/api/artist-image`);
  const json = (await res.json()) as { ok: boolean; data?: { url: string } };
  if (json.ok && json.data?.url) artistImage = json.data.url;
} catch (err) {
  console.warn('[Bio.astro] no se pudo fetch /api/artist-image en build time, usando fallback', err);
}
const altText = lang === 'es' ? 'Foto del artista NORAC X' : 'Artist photo of NORAC X';
---

<section class="bio" id="bio">
  <div class="bio-grid">
    <aside class="bio-side">
      <div class="bio-side-image">
        <img src={artistImage} alt={altText} loading="lazy" decoding="async" />
      </div>

      <div class="bio-meta">
        <div class="bio-meta-row">
          <span>{t.origin}</span>
          <span>Tacna, Perú</span>
        </div>
        <div class="bio-meta-row">
          <span>{t.scope}</span>
          <span>{t.scopeVal}</span>
        </div>
        <div class="bio-meta-row">
          <span>{t.genre}</span>
          <span>{t.genreVal}</span>
        </div>
        <div class="bio-meta-row">
          <span>{t.influences}</span>
          <span>SOAD · Molotov · Pantera · Rammstein</span>
        </div>
        <div class="bio-meta-row">
          <span>{t.format}</span>
          <span>{t.formatVal}</span>
        </div>
        <div class="bio-meta-row">
          <span>{t.tracks}</span>
          <span>7+</span>
        </div>
      </div>
    </aside>

    <div class="bio-content">
      <div class="section-label">{t.label}</div>
      <h2 class="section-title" style="margin-bottom: 48px;" set:html={t.title}></h2>

      <p set:html={t.p1}></p>
      <p set:html={t.p2}></p>

      <div class="bio-pullquote" set:html={t.quote}></div>

      <p set:html={t.p3}></p>
      <p set:html={t.p4}></p>
    </div>
  </div>
</section>
