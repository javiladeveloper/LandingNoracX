---
import { getDict, type Lang } from '@/i18n';

interface Props {
  lang: Lang;
}

interface QuoteRow {
  id: string;
  textEs: string;
  textEn: string;
  sourceName: string;
  order: number;
}

const { lang } = Astro.props;
const t = getDict(lang).lyrics;

// Build-time fetch desde D1 (mismo patrón que Music.astro). En CI
// PUBLIC_API_URL = https://noracx.com.
const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8787';
let allQuotes: QuoteRow[] = [];
try {
  const quotesRes = await fetch(`${apiUrl}/api/quotes`);
  const quotesJson = (await quotesRes.json()) as { ok: boolean; data: QuoteRow[] };
  if (quotesJson.ok) allQuotes = quotesJson.data;
} catch (err) {
  console.warn('[LyricsWall.astro] no se pudo fetch /api/quotes en build time', err);
}
const rows = allQuotes.map((q) => ({
  order: q.order,
  text: lang === 'es' ? q.textEs : q.textEn,
  source: q.sourceName,
}));
---

<section class="lyrics-wall reveal">
  <div class="lyrics-wall-head">
    <div class="section-label">
      <span>{t.label}</span>
      <span class="section-number">/ 03</span>
    </div>
    <h2 class="section-title" set:html={t.title}></h2>
  </div>

  <div class="lyrics-list">
    {
      rows.map((row) => (
        <div class="lyric-row">
          <span class="lyric-number">{row.order.toString().padStart(2, '0')}</span>
          <div class="lyric-text" data-text={row.text}>{row.text}</div>
          <span class="lyric-source">{row.source}</span>
        </div>
      ))
    }
  </div>
</section>

<script>
  // Web Audio API: Synth static glitch noise on hover
  let audioCtx: AudioContext | null = null;
  
  const playGlitch = () => {
    if (!audioCtx) {
      // eslint-disable-next-line @typescript-eslint/no-explicit-any
      audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
    }
    if (audioCtx.state === 'suspended') audioCtx.resume();
    
    const bufferSize = audioCtx.sampleRate * 0.15; // 150ms of noise
    const buffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
    const data = buffer.getChannelData(0);
    for (let i = 0; i < bufferSize; i++) {
      data[i] = Math.random() * 2 - 1; // White noise
    }
    
    const noiseSource = audioCtx.createBufferSource();
    noiseSource.buffer = buffer;
    
    // Bandpass filter to make it sound like a radio/TV glitch
    const filter = audioCtx.createBiquadFilter();
    filter.type = 'bandpass';
    filter.frequency.value = 800 + Math.random() * 3000;
    
    const gainNode = audioCtx.createGain();
    gainNode.gain.setValueAtTime(0.04, audioCtx.currentTime); // Low volume
    gainNode.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.1);
    
    noiseSource.connect(filter);
    filter.connect(gainNode);
    gainNode.connect(audioCtx.destination);
    
    noiseSource.start();
  };

  document.querySelectorAll('.lyric-row').forEach(row => {
    row.addEventListener('mouseenter', playGlitch);
  });
</script>
