---
import { getDict, type Lang } from '@/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getDict(lang).platforms;

const streaming = [
  {
    name: 'Spotify',
    handle: 'NORAC X',
    href: 'https://open.spotify.com/artist/23reXrP1oSrpgNVFHIEGk6',
    icon: 'spotify',
  },
  {
    name: 'YouTube Music',
    handle: 'NORAC X',
    href: 'https://music.youtube.com/@Norac_X',
    icon: 'youtube-music',
  },
  {
    name: 'Apple Music',
    handle: 'NORAC X',
    href: 'https://music.apple.com/us/artist/norac-x/1875118578',
    icon: 'apple-music',
  },
] as const;

const socials = [
  {
    name: 'YouTube',
    handle: '@norac_x',
    href: 'https://www.youtube.com/@norac_x',
    icon: 'youtube',
  },
  {
    name: 'TikTok',
    handle: '@norac_x',
    href: 'https://www.tiktok.com/@norac_x',
    icon: 'tiktok',
  },
  {
    name: 'Instagram',
    handle: '@noracx_official',
    href: 'https://www.instagram.com/noracx_official',
    icon: 'instagram',
  },
  {
    name: 'Facebook',
    handle: 'NORAC X',
    href: 'https://www.facebook.com/profile.php?id=61575460841628',
    icon: 'facebook',
  },
] as const;
---

<section class="section platforms-section" id="plataformas">
  <div class="section-head">
    <div>
      <div class="section-label">
        <span>{t.label}</span>
        <span class="section-number">/ 05</span>
      </div>
      <h2 class="section-title" set:html={t.title}></h2>
    </div>
    <p class="section-intro">{t.intro}</p>
  </div>

  <div class="platforms-group">
    <h3 class="platforms-group-title">Streaming</h3>
    <div class="platforms-grid">
      {
        streaming.map((p) => (
          <a href={p.href} class="platform" target="_blank" rel="noopener">
            <div class="platform-icon">
              {p.icon === 'spotify' && (
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.36-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.42 1.56-.301.421-1.02.599-1.561.3z" /></svg>
              )}
              {p.icon === 'youtube-music' && (
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 0C5.376 0 0 5.376 0 12s5.376 12 12 12 12-5.376 12-12S18.624 0 12 0zm0 19.2c-3.984 0-7.2-3.216-7.2-7.2S8.016 4.8 12 4.8s7.2 3.216 7.2 7.2-3.216 7.2-7.2 7.2zm0-13.056c-3.216 0-5.856 2.64-5.856 5.856S8.784 17.856 12 17.856s5.856-2.64 5.856-5.856S15.216 6.144 12 6.144zm-1.728 8.4V9.408L14.4 12l-4.128 2.544z" /></svg>
              )}
              {p.icon === 'apple-music' && (
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M23.997 6.124a9.2 9.2 0 0 0-.215-2.057 3.4 3.4 0 0 0-3.097-2.69c-.288-.024-.594-.05-.864-.07L19.706 1H4.281a37.4 37.4 0 0 0-.864.07A3.4 3.4 0 0 0 .32 3.76a9.2 9.2 0 0 0-.215 2.067C.099 6.207.099 6.609.099 7.01v9.98c0 .4 0 .803.006 1.183.025.679.064 1.366.215 2.057a3.4 3.4 0 0 0 3.097 2.69c.288.024.594.05.864.07l.115.007h15.205l.114-.007c.27-.02.575-.046.864-.07a3.4 3.4 0 0 0 3.097-2.69c.151-.69.19-1.378.215-2.057.005-.38.006-.782.006-1.183V7.01c0-.4 0-.803-.006-1.183zM17.36 6.99v8.65c0 .76-.06 1.5-.66 2.05a3.16 3.16 0 0 1-1.84.85c-1.4.15-2.45-.76-2.45-2.07 0-1.14.86-1.85 2-2.04l.93-.16c.5-.08.74-.27.74-.78V7.94c0-.34-.16-.5-.5-.43l-7.36 1.52c-.34.07-.46.24-.46.59v9.45c0 .77-.07 1.5-.67 2.05-.46.42-1.13.72-1.83.85-1.4.15-2.45-.76-2.45-2.07 0-1.14.86-1.85 2-2.04l.93-.16c.5-.08.74-.27.74-.78V6.4c0-.4.16-.66.6-.75l9.92-2c.27-.05.53-.05.53.34z" /></svg>
              )}
            </div>
            <div>
              <div class="platform-name">{p.name}</div>
              <div class="platform-handle">{p.handle}</div>
            </div>
          </a>
        ))
      }
    </div>
  </div>

  <div class="platforms-group">
    <h3 class="platforms-group-title">Socials</h3>
    <div class="platforms-grid">
      {
        socials.map((p) => (
          <a href={p.href} class="platform" target="_blank" rel="noopener">
            <div class="platform-icon">
              {p.icon === 'youtube' && (
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" /></svg>
              )}
              {p.icon === 'tiktok' && (
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1.84-.1z" /></svg>
              )}
              {p.icon === 'instagram' && (
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z" /></svg>
              )}
              {p.icon === 'facebook' && (
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" /></svg>
              )}
            </div>
            <div>
              <div class="platform-name">{p.name}</div>
              <div class="platform-handle">{p.handle}</div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
