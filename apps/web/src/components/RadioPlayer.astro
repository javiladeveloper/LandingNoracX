---
// Playlist público en Spotify con todas las canciones de NORAC X.
// Para agregar/quitar/reordenar canciones: editar la playlist directamente
// en Spotify, no requiere deploy. El embed de playlist maneja el
// auto-advance internamente — esto resuelve el problema de que la
// siguiente canción no arrancaba en pestañas ocultas: ahora Spotify
// hace el cambio de track dentro del propio iframe, sin depender de
// llamadas play() externas que el browser bloquea en background tabs.
const playlistId = '25MZuM2WpO8BpPIZMncSzR';
---

<div id="radio-player" class="radio-player radio-player--collapsed">
  <button id="radio-toggle" class="radio-toggle" aria-label="Toggle Radio NORAC X">
    <span class="radio-toggle-icon">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/>
      </svg>
    </span>
    <span class="radio-toggle-label">RADIO NORAC X</span>
    <span class="radio-toggle-live"><span class="live-dot"></span>LIVE</span>
    <span class="radio-toggle-chevron">▲</span>
  </button>

  <div class="radio-body">
    <iframe
      id="radio-spotify-iframe"
      src={`https://open.spotify.com/embed/playlist/${playlistId}?utm_source=generator&theme=0`}
      width="100%" height="352"
      allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
      title="NORAC X Radio Player"
    ></iframe>
  </div>
</div>

<style>
  .radio-player { position: fixed; bottom: 0; left: 0; right: 0; z-index: 999; font-family: 'JetBrains Mono', monospace; }
  .radio-player--collapsed .radio-body { display: none; }

  .radio-toggle {
    display: flex; align-items: center; gap: 10px;
    background: #0a0a0a; border: 1px solid rgba(230,10,10,0.5); border-bottom: none;
    color: #e60a0a; padding: 8px 20px; cursor: pointer;
    font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.25em; text-transform: uppercase;
    margin-left: 20px; border-radius: 4px 4px 0 0;
    box-shadow: 0 -4px 20px rgba(230,10,10,0.15); transition: background 0.2s;
  }
  .radio-toggle:hover { background: #111; }
  .radio-toggle-label { color: #f5f0e8; font-weight: 700; }
  .radio-toggle-live { display: flex; align-items: center; gap: 5px; color: #e60a0a; font-size: 9px; letter-spacing: 0.3em; }
  .live-dot { width: 6px; height: 6px; background: #e60a0a; border-radius: 50%; animation: pulse 1.5s infinite; box-shadow: 0 0 6px #e60a0a; }
  @keyframes pulse { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.4; transform: scale(0.8); } }
  .radio-toggle-chevron { color: #555; font-size: 10px; transition: transform 0.3s; }
  .radio-player:not(.radio-player--collapsed) .radio-toggle-chevron { transform: rotate(180deg); }

  .radio-body {
    background: #050505; border-top: 1px solid rgba(230,10,10,0.4);
    overflow: hidden;
    box-shadow: 0 -10px 40px rgba(0,0,0,0.8);
  }
  .radio-body iframe { display: block; width: 100%; border: none; }
</style>

<script>
  const player = document.getElementById('radio-player');
  const toggleBtn = document.getElementById('radio-toggle');
  if (player && toggleBtn) {
    toggleBtn.addEventListener('click', () => player.classList.toggle('radio-player--collapsed'));
  }
</script>
