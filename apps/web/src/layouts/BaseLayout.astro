---
import '@/styles/global.css';
// Self-hosted fonts — servidas desde Cloudflare Pages, sin request a Google.
// Mejora LCP/CLS (sin FOUT de terceros), GDPR-friendly, sin DNS lookup externo.
import '@fontsource/archivo-black';
import '@fontsource/bebas-neue';
import '@fontsource/space-grotesk/300.css';
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/500.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/jetbrains-mono/700.css';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import { getDict, type Lang, altLang, localizePath } from '@/i18n';
import { getArtistImage } from '@/lib/artistImage';

interface Props {
  lang: Lang;
  pageTitle?: string;
  pagePath?: string;
  /**
   * Description específica de la página, sobreescribe la default del dict.
   * Usada en song detail pages para que cada URL tenga su propia meta description
   * y og:description — mejora ranking y CTR en SERP.
   */
  pageDescription?: string;
  /**
   * BreadcrumbList items, se inyectan como JSON-LD si están presentes.
   * Cada item: { name, item (URL absoluta) }.
   */
  breadcrumbs?: Array<{ name: string; item: string }>;
}

const { lang, pageTitle, pagePath = '/', pageDescription, breadcrumbs } = Astro.props;
const dict = getDict(lang);
const title = pageTitle ?? dict.meta.title;
const description = pageDescription ?? dict.meta.description;
const ogDescription = pageDescription ?? dict.meta.ogDescription;

const currentPath = localizePath(pagePath, lang);
const canonicalUrl = new URL(currentPath, Astro.site ?? 'https://noracx.com').href;
const alt = altLang(lang);
const altPath = localizePath(pagePath, alt);
const altUrl = new URL(altPath, Astro.site ?? 'https://noracx.com').href;

const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8787';

// Foto del artista dinámica (Spotify Web API via /api/artist-image, memoizada).
// Usada en og:image, twitter:image y JSON-LD image. Si el artista actualiza
// la foto en Spotify, todos los previews sociales se actualizan en el siguiente
// rebuild sin tocar código.
const artistImage = await getArtistImage();
const pixelId = import.meta.env.PUBLIC_META_PIXEL_ID;

const platformsHref = localizePath('/#plataformas', lang);
const listenText = lang === 'es' ? 'Escuchar Ahora' : 'Listen Now';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#000000" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="NORAC X" />
    <link rel="canonical" href={canonicalUrl} />

    <link rel="alternate" hreflang={lang} href={canonicalUrl} />
    <link rel="alternate" hreflang={alt} href={altUrl} />
    <link rel="alternate" hreflang="x-default" href={new URL('/', Astro.site ?? 'https://noracx.com').href} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/icon-maskable.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <meta property="og:type" content="music.musician" />
    <meta property="og:site_name" content="NORAC X" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={dict.meta.locale} />
    <meta property="og:image" content={new URL('/og-image.jpg', Astro.site ?? 'https://noracx.com').href} />
    <meta property="og:image:width" content="640" />
    <meta property="og:image:height" content="640" />
    <meta property="og:image:alt" content="NORAC X — Metal Peruano de Protesta" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@norac_x" />
    <meta name="twitter:creator" content="@norac_x" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={new URL('/og-image.jpg', Astro.site ?? 'https://noracx.com').href} />

    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'MusicGroup',
      name: 'NORAC X',
      url: 'https://noracx.com',
      logo: 'https://noracx.com/favicon.svg',
      image: artistImage,
      description: dict.meta.description,
      foundingLocation: {
        '@type': 'Place',
        name: 'Tacna, Perú',
      },
      foundingDate: '2026',
      genre: ['Heavy Metal', 'Protest Metal', 'Alternative Metal', 'Metal en Castellano'],
      sameAs: [
        'https://open.spotify.com/artist/23reXrP1oSrpgNVFHIEGk6',
        'https://music.apple.com/search?term=NORAC+X',
        'https://music.youtube.com/search?q=NORAC+X',
        'https://www.youtube.com/@norac_x',
        'https://www.tiktok.com/@norac_x',
        'https://www.instagram.com/noracx_official',
        'https://www.facebook.com/profile.php?id=61575460841628',
      ],
      email: 'contacto@noracx.com',
    })}></script>

    {breadcrumbs && breadcrumbs.length > 0 && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: breadcrumbs.map((b, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: b.name,
          item: b.item,
        })),
      })}></script>
    )}

    <!-- Fonts self-hosted via fontsource — importadas en el frontmatter arriba -->

    <script is:inline>
      (function () {
        try {
          const isBot = /bot|googlebot|crawler|spider|robot|crawling/i.test(navigator.userAgent);
          if (isBot) return;
          const path = window.location.pathname;
          const isEn = path === '/en' || path === '/en/' || path.startsWith('/en/');
          const saved = localStorage.getItem('noracx-lang');
          if (saved === 'en' && !isEn) {
            window.location.replace('/en' + (path === '/' ? '' : path));
            return;
          }
          if (saved === 'es' && isEn) {
            const stripped = path.replace(/^\/en/, '') || '/';
            window.location.replace(stripped);
            return;
          }
          if (!saved && !isEn && navigator.language && navigator.language.toLowerCase().startsWith('en')) {
            window.location.replace('/en' + (path === '/' ? '' : path));
          }
        } catch (_e) {
          /* localStorage no disponible */
        }
      })();
    </script>

    {pixelId && (
      <Fragment>
        {/* Meta Pixel Code */}
        <script is:inline define:vars={{ pixelId }}>
          /* eslint-disable */
          !function(f,b,e,v,n,t,s)
          {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
          n.callMethod.apply(n,arguments):n.queue.push(arguments)};
          if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
          n.queue=[];t=b.createElement(e);t.async=!0;
          t.src=v;s=b.getElementsByTagName(e)[0];
          s.parentNode.insertBefore(t,s)}(window, document,'script',
          'https://connect.facebook.net/en_US/fbevents.js');
          fbq('init', pixelId);
          fbq('track', 'PageView');
          /* eslint-enable */
        </script>
        <noscript><img height="1" width="1" style="display:none"
          src={`https://www.facebook.com/tr?id=${pixelId}&ev=PageView&noscript=1`}
        /></noscript>
      </Fragment>
    )}
  </head>
  <body>
    <div id="preloader" class="preloader">
      <div class="preloader-terminal">
        <p id="boot-text"></p><span class="blink">_</span>
      </div>
    </div>

    <div class="cursor" id="cursor"></div>

    <Nav lang={lang} pagePath={pagePath} />

    <main>
      <slot />
    </main>

    <Footer lang={lang} />

    <a href={platformsHref} class="floating-music" aria-label={listenText}>
      <svg viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm0 22C6.486 22 2 17.514 2 12S6.486 2 12 2s10 4.486 10 10-4.486 10-10 10zm-2.5-13.5v7l6-3.5-6-3.5z"/>
      </svg>
      <span class="fs-text">{listenText}</span>
    </a>

    <script is:inline define:vars={{ apiUrl, lang }}>
      // Tracking de pageview — server-side, sin cookies de terceros.
      // sessionId vive en sessionStorage (no persiste entre pestañas cerradas).
      (function () {
        try {
          let sid = sessionStorage.getItem('nx-sid');
          if (!sid) {
            sid =
              typeof crypto !== 'undefined' && crypto.randomUUID
                ? crypto.randomUUID()
                : Math.random().toString(36).slice(2) + Date.now().toString(36);
            sessionStorage.setItem('nx-sid', sid);
          }
          fetch(apiUrl + '/api/track', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              path: window.location.pathname,
              referrer: document.referrer || undefined,
              sessionId: sid,
              language: lang,
            }),
            keepalive: true,
          }).catch(() => {
            /* tracking es best-effort, no rompemos UX si falla */
          });
        } catch (_e) {
          /* sessionStorage no disponible */
        }
      })();
    </script>

    <script>
      // Persistencia de idioma elegido por el usuario
      const langBtns = document.querySelectorAll<HTMLAnchorElement>('[data-lang]');
      langBtns.forEach((btn) => {
        btn.addEventListener('click', () => {
          const lang = btn.dataset.lang;
          if (lang === 'es' || lang === 'en') {
            try {
              localStorage.setItem('noracx-lang', lang);
            } catch {
              /* ignore */
            }
          }
        });
      });

      // Nav scroll state
      const nav = document.getElementById('nav');
      if (nav) {
        const onScroll = () => {
          if (window.scrollY > 50) nav.classList.add('scrolled');
          else nav.classList.remove('scrolled');
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      }

      // Reveal on scroll
      const revealEls = document.querySelectorAll('.reveal');
      if (revealEls.length > 0) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('in');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1 },
        );
        revealEls.forEach((el) => observer.observe(el));
      }

      // Custom cursor (solo cuando hay puntero fino, ej. mouse)
      const cursor = document.getElementById('cursor');
      if (cursor && window.matchMedia('(pointer: fine)').matches) {
        document.addEventListener('mousemove', (e) => {
          cursor.style.left = e.clientX + 'px';
          cursor.style.top = e.clientY + 'px';
        });
        document
          .querySelectorAll('a, button, .track, .platform, .lyric-row')
          .forEach((el) => {
            el.addEventListener('mouseenter', () => cursor.classList.add('hover'));
            el.addEventListener('mouseleave', () => cursor.classList.remove('hover'));
          });
      } else if (cursor) {
        cursor.style.display = 'none';
      }

      // Preloader Terminal Boot Sequence
      const bootText = document.getElementById('boot-text');
      const preloader = document.getElementById('preloader');
      if (bootText && preloader) {
        // Fast sequence for a quick entry
        const msgs = ['[INICIANDO PROTOCOLO]', '[SINTONIZANDO VOZ DEL PUEBLO]... 100%', 'NORAC X_'];
        let idx = 0;
        const interval = setInterval(() => {
          if (idx < msgs.length) {
            bootText.innerText = msgs[idx] || '';
            idx++;
          } else {
            clearInterval(interval);
            setTimeout(() => {
              preloader.classList.add('hidden');
              // Remove from DOM after transition
              setTimeout(() => preloader.remove(), 600);
            }, 200);
          }
        }, 300);
      }

    </script>
  </body>
</html>
