---
import '@/styles/global.css';

interface Props {
  title: string;
  description?: string;
  lang?: 'es' | 'en';
}

const {
  title,
  description = 'NORAC X. Metal peruano de protesta desde Tacna.',
  lang = 'es',
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#000000" />
    <meta name="description" content={description} />
    <link rel="canonical" href={Astro.url.href} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
