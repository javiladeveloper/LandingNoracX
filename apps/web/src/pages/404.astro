---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout lang="es" pageTitle="404 — NORAC X" pagePath="/">
  <section class="not-found-section">
    <div class="not-found-grid">
      <p class="not-found-label" id="nf-label">404 · página perdida</p>
      <h1 class="not-found-title">
        Esto <em id="nf-no">no</em> <span id="nf-exists">existe</span>
      </h1>
      <p class="not-found-body" id="nf-body">
        La URL que pediste no llegó a ninguna parte. Quizás la escribiste mal, o
        desapareció con el sistema.
      </p>
      <div class="not-found-cta">
        <a href="/" id="nf-home" class="btn btn-primary"><span id="nf-home-label">Volver al grito</span></a>
        <a href="/#musica" id="nf-music" class="btn"><span id="nf-music-label">Ir a la música</span></a>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  (function () {
    const isEn = window.location.pathname.startsWith('/en');
    if (!isEn) return;
    // Swap text to English and fix links
    document.getElementById('nf-label').textContent   = '404 · page not found';
    document.getElementById('nf-no').textContent      = "doesn't";
    document.getElementById('nf-exists').textContent  = 'exist';
    document.getElementById('nf-body').textContent    =
      'The URL you requested leads nowhere. Maybe you mistyped it, or it vanished with the system.';
    document.getElementById('nf-home').href           = '/en';
    document.getElementById('nf-home-label').textContent = 'Back to the sound';
    document.getElementById('nf-music').href          = '/en/#musica';
    document.getElementById('nf-music-label').textContent = 'Go to music';
    document.querySelector('html').lang               = 'en';
    document.title                                    = '404 — NORAC X';
  })();
</script>

<style>
  .not-found-section {
    min-height: calc(100vh - 120px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 120px 40px 80px;
  }
  .not-found-grid {
    max-width: 720px;
    text-align: center;
  }
  @media (max-width: 600px) {
    .not-found-section {
      padding: 96px 20px 60px;
    }
  }
  .not-found-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--blood-bright);
    margin-bottom: 24px;
  }
  .not-found-title {
    font-family: 'Archivo Black', sans-serif;
    font-size: clamp(60px, 12vw, 140px);
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--bone);
    margin-bottom: 32px;
  }
  .not-found-title em {
    color: var(--blood-bright);
    font-style: italic;
    text-shadow: 0 0 40px rgba(230, 10, 10, 0.6);
  }
  .not-found-body {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 18px;
    line-height: 1.6;
    color: var(--ink);
    margin-bottom: 40px;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }
  .not-found-cta {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
