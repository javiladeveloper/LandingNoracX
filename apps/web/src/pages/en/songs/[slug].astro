---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SongDetail, { type SongDetailData } from '@/components/SongDetail.astro';

export async function getStaticPaths() {
  const apiUrl = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8787';
  try {
    const res = await fetch(`${apiUrl}/api/songs`);
    const json = (await res.json()) as { ok: boolean; data: SongDetailData[] };
    if (!json.ok) return [];
    return json.data.map((song) => ({ params: { slug: song.slug }, props: { song } }));
  } catch (err) {
    console.warn('[en/songs/[slug]] no se pudo fetch /api/songs', err);
    return [];
  }
}

const { song } = Astro.props as { song: SongDetailData };
const lang = 'en' as const;
const pageTitle = `${song.title} — Lyrics and video · NORAC X`;
function trim(text: string, max = 155): string {
  if (!text) return text;
  if (text.length <= max) return text;
  return text.slice(0, max - 1).replace(/\s+\S*$/, '') + '…';
}
const pageDescription = trim(
  `${song.title} by NORAC X — ${song.themesEn}`,
);
const breadcrumbs = [
  { name: 'Home', item: 'https://noracx.com/en' },
  { name: 'Songs', item: 'https://noracx.com/en/#musica' },
  { name: song.title, item: `https://noracx.com/en/songs/${song.slug}` },
];
---

<BaseLayout
  lang={lang}
  pageTitle={pageTitle}
  pagePath={`/songs/${song.slug}`}
  pageDescription={pageDescription}
  breadcrumbs={breadcrumbs}
>
  <SongDetail lang={lang} song={song} />
</BaseLayout>
