---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import Marquee from '@/components/Marquee.astro';
import Bio from '@/components/Bio.astro';
import Music from '@/components/Music.astro';
import LyricsWall from '@/components/LyricsWall.astro';
import Newsletter from '@/components/Newsletter.astro';
import Platforms from '@/components/Platforms.astro';
import SongSuggestions from '@/components/SongSuggestions.astro';
import Contact from '@/components/Contact.astro';

const lang = 'es' as const;
---

<BaseLayout lang={lang} pagePath="/">
  <Hero lang={lang} />
  <Marquee lang={lang} />
  <Bio lang={lang} />
  <Music lang={lang} />
  <LyricsWall lang={lang} />
  <Newsletter lang={lang} />
  <Platforms lang={lang} />
  <SongSuggestions lang={lang} />
  <Contact lang={lang} />
</BaseLayout>
